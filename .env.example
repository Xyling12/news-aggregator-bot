# ── Required ────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# ── AI: Gemini (primary) ─────────────────────────────
# Multiple keys separated by comma — each has own free quota
GEMINI_API_KEYS=key1,key2,key3

# ── AI: YandexGPT (fallback when Gemini quota exhausted) ─
# Get from console.yandex.cloud → IAM → Service Account → API Keys
YANDEX_API_KEY=AQVN...
YANDEX_FOLDER_ID=b1g...

# ── AI: Groq (optional second fallback, if available) ──
# Get from console.groq.com — free 14,400 req/day
# GROQ_API_KEY=gsk_...

# ── Telegram channels ────────────────────────────────
TARGET_CHANNEL=@YourChannel
SOURCE_CHANNELS=channel1,channel2,channel3
ADMIN_IDS=123456789

# ── Publishing settings ───────────────────────────────
AUTO_PUBLISH=true
PUBLISH_INTERVAL=900

# ── VK crossposting (optional) ───────────────────────
VK_GROUP_ID=
VK_ACCESS_TOKEN=
