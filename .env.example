# ── Required ────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# ── AI: AITUNNEL (primary — OpenAI-compatible) ──────
# Register at https://aitunnel.ru — ~300₽/month for GPT-4o-mini
AITUNNEL_API_KEY=sk-aitunnel-...
AITUNNEL_MODEL=gpt-4o-mini

# ── AI: Gemini (fallback) ────────────────────────────
# Multiple keys separated by comma — each has own free quota
GEMINI_API_KEYS=key1,key2,key3

# ── AI: YandexGPT (fallback) ────────────────────────
# Get from console.yandex.cloud → IAM → Service Account → API Keys
YANDEX_API_KEY=AQVN...
YANDEX_FOLDER_ID=b1g...

# ── AI: Groq (fallback, free 14,400 req/day) ────────
# GROQ_API_KEY=gsk_...

# ── Stock Photos (free) ──────────────────────────────
# Pexels — best quality, 200 req/hour. Register: https://www.pexels.com/api/
PEXELS_API_KEY=
# Pixabay — good variety. Register: https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# ── Telegram channels ────────────────────────────────
TARGET_CHANNEL=@YourChannel
SOURCE_CHANNELS=channel1,channel2,channel3
ADMIN_IDS=123456789

# ── Publishing settings ──────────────────────────────
AUTO_PUBLISH=true
PUBLISH_INTERVAL=900

# ── VK crossposting (optional) ──────────────────────
VK_GROUP_ID=
VK_ACCESS_TOKEN=
# Required for VK Clips/Stories upload (user token with video,stories,photos scope)
VK_USER_TOKEN=
VK_SEO_ENABLED=true
VK_SEO_MAX_TAGS=9
# Disable first-comment under own VK posts by default
VK_SELF_COMMENT_ENABLED=false
# Disable source-channel media usage by default (avoids чужие водяные знаки/брендинг)
USE_SOURCE_MEDIA=false

# Optional: commenting under competitor/community posts from group (careful mode)
VK_COMPETITOR_COMMENTING_ENABLED=true
# Examples: club123456, public123456, domain_name, https://vk.com/domain_name
VK_COMPETITOR_TARGETS=https://vk.com/izhevsk.life,https://vk.com/typical_izhev,https://vk.com/iggs18,https://vk.com/izhevsk__life,https://vk.com/izhevsk_online,https://vk.com/darom_vip18,https://vk.com/poisky
# Optional keyword filter for external posts (comma-separated)
VK_COMPETITOR_KEYWORDS=ижевск,удмуртия,дтп,жкх,транспорт
# Per target/community daily limit
VK_COMPETITOR_COMMENTS_PER_DAY=2
VK_COMPETITOR_MIN_GAP_MINUTES=480
VK_COMPETITOR_SCAN_LIMIT=6
