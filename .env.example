# === Telegram API (для Telethon - чтение каналов) ===
# Получить на https://my.telegram.org/apps
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# === Telegram Bot (для Aiogram - управление и постинг) ===
# Получить у @BotFather
BOT_TOKEN=your_bot_token

# === Целевой канал для публикации ===
# Username канала (без @) или chat_id
TARGET_CHANNEL=your_channel_username

# === Админы (Telegram user IDs через запятую) ===
ADMIN_IDS=123456789

# === Google Gemini API ===
# Получить на https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key
# Опционально: список моделей через запятую. Если не задан, бот сам попробует
# актуальный набор fallback-моделей.
# GEMINI_MODEL_NAMES=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.5-pro,gemini-2.0-flash,gemini-2.0-flash-lite

# === YandexGPT API (fallback для рерайта) ===
# Получить на https://console.yandex.cloud
YANDEX_API_KEY=your_yandex_api_key
YANDEX_FOLDER_ID=your_folder_id

# === Groq API (fallback for rewrite) ===
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# === Каналы-источники (через запятую) ===
# Без @, например: ria_novosti,tass_agency,rbc_news
SOURCE_CHANNELS=channel1,channel2

# === Стоковые фото (для иллюстраций к новостям) ===
# Pixabay — ОСНОВНОЙ источник. Бесплатно, поддерживает русские теги.
# Регистрация и ключ: https://pixabay.com/api/docs/
PIXABAY_API_KEY=
# Unsplash — РЕЗЕРВНЫЙ источник (используется если Pixabay не настроен / ничего не нашёл).
UNSPLASH_ACCESS_KEY=

# === Опционально: ReText.AI API (fallback для рерайта) ===
RETEXT_API_KEY=

# === Настройки ===
# Минимальная длина текста для обработки (символов)
MIN_TEXT_LENGTH=100
# Задержка между проверками каналов (секунд)
CHECK_INTERVAL=60
# Язык рерайта
LANGUAGE=ru
